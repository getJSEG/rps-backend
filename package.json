{
  "name": "elmer-backend",
  "version": "1.0.0",
  "description": "Backend API for Elmer E-commerce Platform",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx nodemon src/server.js",
    "migrate": "node src/migrations/runMigrations.js",
    "migrate:pricing": "node src/migrations/runAddPricingColumns.js",
    "migrate:employees": "node src/migrations/runEmployeeColumns.js",
    "migrate:retail-customers": "node src/migrations/runRetailCustomers.js",
    "seed": "node src/migrations/seed.js",
    "seed-subcategory-products": "node src/migrations/seedSubcategoryProducts.js",
    "create-admin": "node src/migrations/createAdminUser.js"
  },
  "keywords": [
    "express",
    "postgresql",
    "api",
    "ecommerce"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "sharp": "^0.34.5",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
